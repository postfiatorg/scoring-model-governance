# Local development configuration. Copy to .env and adjust as needed.
# The docker-compose Postgres publishes host port 5433 so it can run next to
# the dynamic-unl-scoring stack, which occupies 5432.
DATABASE_URL=postgresql://postgres:dev_password@localhost:5433/scoring_model_governance

# Optional HuggingFace API token for candidate sourcing (public repos work
# without one; a token raises rate limits and resolves gated metadata).
# HF_TOKEN=

# API key for admin endpoints (the pool-refresh trigger). The endpoints
# return 403 until a key is configured.
# ADMIN_API_KEY=

# Incumbent serving artifact. The repository defaults to the production
# scoring model; set the revision to the execution manifest's pin when the
# refresh record must carry the exact serving revision.
# INCUMBENT_HF_REPO=Qwen/Qwen3.6-27B-FP8
# INCUMBENT_REVISION=

# Deployment environment name recorded in published refresh records.
# ENVIRONMENT=local

# IPFS pinning of refresh snapshot files. Pinning is skipped when the API
# URL is empty; Pinata replication is skipped without both credentials.
# IPFS_API_URL=
# IPFS_API_USERNAME=
# IPFS_API_PASSWORD=
# PINATA_API_KEY=
# PINATA_API_SECRET=

# Automatic record publication to the governance repository. Publication
# is skipped (publication_status = SKIPPED) when the token is empty.
# RECORDS_GITHUB_TOKEN=
# RECORDS_GITHUB_REPO=postfiatorg/scoring-model-governance
# RECORDS_GITHUB_BRANCH=main
