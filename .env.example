# Local development configuration. Copy to .env and adjust as needed.
# The docker-compose Postgres publishes host port 5433 so it can run next to
# the dynamic-unl-scoring stack, which occupies 5432.
DATABASE_URL=postgresql://postgres:dev_password@localhost:5433/scoring_model_governance

# Optional HuggingFace API token for candidate sourcing (public repos work
# without one; a token raises rate limits and resolves gated metadata).
# HF_TOKEN=
